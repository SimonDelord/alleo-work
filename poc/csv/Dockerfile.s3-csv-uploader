FROM python:3.12-slim

WORKDIR /app
COPY requirements.s3-csv-uploader.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY fleet_telemetry_data.py s3_csv_uploader.py /app/

# Runs in OpenShift: builds fleet CSV, uploads to S3 on an interval. Needs AWS
# creds (Secret) or IRSA. No laptop / host filesystem required.
CMD ["python", "/app/s3_csv_uploader.py"]
