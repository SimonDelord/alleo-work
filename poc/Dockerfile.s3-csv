# Minimal deps; do not use the repo-wide requirements.txt here (pymodbus + cache issues).
FROM python:3.12-slim

WORKDIR /app
COPY requirements.s3-csv-producer.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY s3_csv_producer.py /app/s3_csv_producer.py

CMD ["python", "/app/s3_csv_producer.py"]
